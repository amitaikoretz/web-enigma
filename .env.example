# PostgreSQL connection used by the API and live runtime services.
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/backtest

# Redis connection used by live runtime state and the /live/runtime API endpoint.
REDIS_URL=redis://localhost:6379/0
REDIS_KEY_PREFIX=ta

# Required for Alpaca-backed market data and paper/live execution paths.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
